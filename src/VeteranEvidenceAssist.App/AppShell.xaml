<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VeteranEvidenceAssist.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:VeteranEvidenceAssist.App.Pages"
    Title="VeteranEvidenceAssist">

    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate pages:DashboardPage}"
        Route="dashboard" />

    <ShellContent
        Title="Documents"
        ContentTemplate="{DataTemplate pages:DocumentsPage}"
        Route="documents" />

    <ShellContent
        Title="Review"
        ContentTemplate="{DataTemplate pages:DocumentReviewPage}"
        Route="document-review" />

    <ShellContent
        Title="Redactions"
        ContentTemplate="{DataTemplate pages:RedactionReviewPage}"
        Route="redactions" />

    <ShellContent
        Title="Evidence Timeline"
        ContentTemplate="{DataTemplate pages:EvidenceTimelinePage}"
        Route="evidence-timeline" />

    <ShellContent
        Title="Prompt Builder"
        ContentTemplate="{DataTemplate pages:PromptBuilderPage}"
        Route="prompt-builder" />

    <ShellContent
        Title="Exports"
        ContentTemplate="{DataTemplate pages:ExportsPage}"
        Route="exports" />

    <ShellContent
        Title="Settings"
        ContentTemplate="{DataTemplate pages:SettingsPage}"
        Route="settings" />

</Shell>
