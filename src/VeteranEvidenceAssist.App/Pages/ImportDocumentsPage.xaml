<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:VeteranEvidenceAssist.Core.Models;assembly=VeteranEvidenceAssist.Core"
             x:Class="VeteranEvidenceAssist.App.Pages.ImportDocumentsPage"
             Title="Import Documents">
    <VerticalStackLayout Padding="24" Spacing="14">
        <Label Text="Import Documents" Style="{StaticResource Headline}" />
        <Label Text="Import DD-214s, service treatment records, VA medical records, private medical records, and scanned PDFs for local processing."
               LineBreakMode="WordWrap" />
        <Button x:Name="ChooseFilesButton"
                Text="Choose PDF"
                Clicked="OnChoosePdfClicked" />
        <Label x:Name="StatusLabel"
               Text="No document imported yet."
               LineBreakMode="WordWrap" />
        <CollectionView x:Name="DocumentsView">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:VeteranDocument">
                    <Grid Padding="0,10"
                          ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto">
                        <Label Text="{Binding OriginalFileName}"
                               FontAttributes="Bold" />
                        <Label Grid.Column="1"
                               Text="{Binding Pages.Count, StringFormat='{0} pages'}" />
                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding Sha256Hash}"
                               FontSize="12"
                               LineBreakMode="TailTruncation" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
