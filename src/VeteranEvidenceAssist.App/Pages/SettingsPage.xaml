<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VeteranEvidenceAssist.App.Pages.SettingsPage"
             Title="Settings">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="24">
            <VerticalStackLayout Spacing="6">
                <Label Text="Settings" Style="{StaticResource Headline}" />
                <Label Text="Local workspace control, appearance, privacy posture, export safety, and future user-configured AI providers."
                       Style="{StaticResource SubHeadline}" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="18" RowSpacing="18">
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Local Workspace" Style="{StaticResource SectionTitle}" />
                        <Border Style="{StaticResource StatusBadge}" HorizontalOptions="Start">
                            <Label Text="Local files only" Style="{StaticResource MetaText}" />
                        </Border>
                        <Label Text="This is the app-managed storage root for imported copies and metadata. Original source files are not moved or edited."
                               Style="{StaticResource MetaText}" />
                        <Label Text="Workspace root" Style="{StaticResource MetaText}" />
                        <Entry x:Name="WorkspacePathEntry" IsReadOnly="True" />
                        <Button Text="Change Workspace" Style="{StaticResource SecondaryButton}" IsEnabled="False" />
                        <Label x:Name="DocumentsPathLabel" Style="{StaticResource MetaText}" />
                        <Label x:Name="MetadataPathLabel" Style="{StaticResource MetaText}" />
                        <Label Text="Cloud upload is off by design in the current phase. Future external AI features must show the exact outgoing payload and require approval first."
                               Style="{StaticResource MetaText}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Privacy &amp; Security" Style="{StaticResource SectionTitle}" />
                        <Label Text="Current import behavior is local-first: preserve originals, store managed copies locally, and require review before any future external transmission."
                               Style="{StaticResource MetaText}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Require review before external transmission" Style="{StaticResource MetaText}" />
                            <Switch Grid.Column="1" IsToggled="True" IsEnabled="False" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Keep imported originals unchanged" Style="{StaticResource MetaText}" />
                            <Switch Grid.Column="1" IsToggled="True" IsEnabled="False" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Record security-sensitive audit events" Style="{StaticResource MetaText}" />
                            <Switch Grid.Column="1" IsToggled="True" IsEnabled="False" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Appearance" Style="{StaticResource SectionTitle}" />
                        <Label Text="Theme" Style="{StaticResource MetaText}" />
                        <Picker x:Name="AppearancePicker"
                                Title="Choose appearance"
                                SelectedIndexChanged="OnAppearanceSelectionChanged" />
                        <Label Text="System Default follows the operating system theme."
                               Style="{StaticResource MetaText}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="AI Providers" Style="{StaticResource SectionTitle}" />
                        <Label Text="No provider is connected in Phase 0.5. Future providers must be user-configured and require payload approval."
                               Style="{StaticResource MetaText}" />
                        <Button Text="Add Provider" Style="{StaticResource SecondaryButton}" IsEnabled="False" />
                        <Label Text="Phase 2 TODO: store provider secrets in OS credential storage, never source control." Style="{StaticResource MetaText}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Export Preferences" Style="{StaticResource SectionTitle}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Confirm before creating redacted export" Style="{StaticResource MetaText}" />
                            <Switch Grid.Column="1" IsToggled="True" IsEnabled="False" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Include source page references in packets" Style="{StaticResource MetaText}" />
                            <Switch Grid.Column="1" IsToggled="True" IsEnabled="False" />
                        </Grid>
                        <Label Text="Phase 2 TODO: configure export folders, redaction audit metadata, and reviewed packet formats."
                               Style="{StaticResource MetaText}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
