<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VeteranEvidenceAssist.App.Pages.DashboardPage"
             Title="Dashboard">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="VeteranEvidenceAssist"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Local-first evidence organizer for sensitive military and medical records."
                   Style="{StaticResource SubHeadline}" />
            <Label Text="No documents or extracted text are sent to cloud services by default. Import, redaction review, evidence organization, and prompt copying stay under user control."
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
