<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VeteranEvidenceAssist.App.Pages.DocumentsPage"
             Title="Documents">
    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="24">
            <VerticalStackLayout Spacing="6">
                <Label Text="Documents" Style="{StaticResource Headline}" />
                <Label Text="Select PDFs, preserve originals, and track local processing status."
                       Style="{StaticResource SubHeadline}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource InfoCallout}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Local intake status" Style="{StaticResource CardTitle}" />
                    <Label Text="Choose PDFs from this device. VeteranEvidenceAssist copies each selected PDF into the local workspace, leaves the original file untouched, stores metadata locally, and does not upload document contents."
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="1.3*,2*" ColumnSpacing="18">
                <VerticalStackLayout Spacing="14">
                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Import Documents" Style="{StaticResource SectionTitle}" />
                            <Label Text="Selected PDFs are copied into app-managed local storage. The source files stay where they are and are not edited."
                                   Style="{StaticResource MetaText}" />
                            <Button x:Name="ChoosePdfsButton"
                                    Text="Choose PDFs"
                                    Clicked="OnChoosePdfsClicked" />
                            <Button Text="Copy Workspace Path"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnCopyWorkspacePathClicked" />
                            <Label x:Name="ImportStatusLabel"
                                   Text="No import running."
                                   Style="{StaticResource MetaText}" />
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Latest Import Results" Style="{StaticResource CardTitle}" />
                                <CollectionView x:Name="ImportResultsCollection"
                                                HeightRequest="150"
                                                EmptyView="No import results yet.">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="10"
                                                  Padding="0,6">
                                                <Border Style="{StaticResource StatusBadge}"
                                                        HorizontalOptions="Start">
                                                    <Label Text="{Binding Status}" Style="{StaticResource MetaText}" />
                                                </Border>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                    <Label Text="{Binding FileName}" Style="{StaticResource CardTitle}" />
                                                    <Label Text="{Binding Detail}" Style="{StaticResource MetaText}" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Local Storage" Style="{StaticResource CardTitle}" />
                            <Border Style="{StaticResource StatusBadge}" HorizontalOptions="Start">
                                <Label Text="Device only" Style="{StaticResource MetaText}" />
                            </Border>
                            <Label Text="Imported PDF copies and document metadata are stored below. Paths may contain user or device names, so review them before sharing screenshots."
                                   Style="{StaticResource MetaText}" />
                            <Label x:Name="WorkspacePathLabel" Style="{StaticResource MetaText}" />
                            <Label x:Name="DocumentsPathLabel" Style="{StaticResource MetaText}" />
                            <Label x:Name="MetadataPathLabel" Style="{StaticResource MetaText}" />
                            <Label Text="Cloud AI transmission is not implemented in this phase."
                                   Style="{StaticResource MetaText}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Label Text="Imported Documents" Style="{StaticResource SectionTitle}" />
                            <Button Grid.Column="1"
                                    Text="Refresh"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnRefreshClicked" />
                        </Grid>
                        <Grid ColumnDefinitions="2*,*,*,*" Padding="0,0,0,8">
                            <Label Text="Name" Style="{StaticResource MetaText}" />
                            <Label Grid.Column="1" Text="Pages" Style="{StaticResource MetaText}" />
                            <Label Grid.Column="2" Text="Text" Style="{StaticResource MetaText}" />
                            <Label Grid.Column="3" Text="Hash" Style="{StaticResource MetaText}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource BorderMuted}" />
                        <CollectionView x:Name="DocumentsCollection"
                                        SelectionMode="Single"
                                        SelectionChanged="OnDocumentSelectionChanged"
                                        EmptyView="No PDFs imported yet.">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="2*,*,*,*"
                                          Padding="0,10"
                                          ColumnSpacing="12">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding OriginalFileName}" Style="{StaticResource CardTitle}" />
                                            <Label Text="{Binding ImportedAtDisplay}" Style="{StaticResource MetaText}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding PageCount}" Style="{StaticResource MetaText}" />
                                        <Label Grid.Column="2" Text="{Binding TextStatus}" Style="{StaticResource MetaText}" />
                                        <Label Grid.Column="3" Text="{Binding ShortHash}" Style="{StaticResource MetaText}" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
