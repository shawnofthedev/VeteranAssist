<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VeteranEvidenceAssist.App.Pages.DocumentReviewPage"
             Title="Document Review">
    <Grid Padding="{StaticResource PagePadding}"
          RowDefinitions="Auto,*"
          RowSpacing="20">
        <VerticalStackLayout Spacing="6">
            <Label Text="Document Review" Style="{StaticResource Headline}" />
            <Label Text="Split-view wireframe for reading pages, checking local extraction, and preserving source provenance."
                   Style="{StaticResource SubHeadline}" />
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              ColumnDefinitions="2.3*,0.9*"
              ColumnSpacing="18">
            <Border Style="{StaticResource Card}">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="4">
                            <Label x:Name="DocumentTitleLabel" Text="Select a document" Style="{StaticResource SectionTitle}" />
                            <Label x:Name="DocumentMetaLabel" Text="Open a document from the Documents page to review extracted text." Style="{StaticResource MetaText}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" Style="{StaticResource StatusBadge}">
                            <Label x:Name="TextStatusLabel" Text="No document" Style="{StaticResource MetaText}" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            BackgroundColor="{StaticResource MutedFill}"
                            Stroke="{StaticResource BorderMuted}"
                            StrokeShape="RoundRectangle 8"
                            Padding="28">
                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
                            <Label Text="Document Viewer Placeholder"
                                   Style="{StaticResource CardTitle}"
                                   HorizontalOptions="Center" />
                            <VerticalStackLayout Grid.Row="1" Spacing="10" VerticalOptions="Center">
                                <BoxView Style="{StaticResource PlaceholderBlock}" WidthRequest="420" HorizontalOptions="Center" />
                                <BoxView Style="{StaticResource PlaceholderBlock}" WidthRequest="520" HorizontalOptions="Center" />
                                <BoxView Style="{StaticResource PlaceholderBlock}" WidthRequest="460" HorizontalOptions="Center" />
                                <BoxView Style="{StaticResource PlaceholderBlock}" WidthRequest="500" HorizontalOptions="Center" />
                                <BoxView Style="{StaticResource PlaceholderBlock}" WidthRequest="390" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <Label Grid.Row="2"
                                   Text="PDF rendering is not implemented yet. Phase 1 stores the local file path, page metadata, and extracted embedded text."
                                   Style="{StaticResource MetaText}"
                                   HorizontalTextAlignment="Center" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Button Text="Previous" Style="{StaticResource SecondaryButton}" IsEnabled="False" />
                        <Slider x:Name="PageSlider" Grid.Column="1" Minimum="1" Maximum="1" Value="1" IsEnabled="False" />
                        <Button Grid.Column="2" Text="Next" Style="{StaticResource SecondaryButton}" IsEnabled="False" />
                    </Grid>
                </Grid>
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="14">
                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Border x:Name="OcrNeededWarning" Style="{StaticResource WarningCallout}" IsVisible="False">
                            <Label Text="This PDF appears to have little or no embedded text. OCR is not implemented yet, so scanned content may not be searchable in this phase."
                                   LineBreakMode="WordWrap" />
                        </Border>
                        <Border Style="{StaticResource InfoCallout}">
                            <Label Text="This review is local-only. The stored PDF copy, metadata, hash, and extracted preview remain in the app workspace unless you explicitly export or share them."
                                   LineBreakMode="WordWrap" />
                        </Border>
                        <Label Text="Document Metadata" Style="{StaticResource SectionTitle}" />
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="ImportedAtUtcLabel" Text="Imported UTC: -" Style="{StaticResource MetaText}" />
                            <Label x:Name="Sha256Label" Text="SHA-256: -" Style="{StaticResource MetaText}" LineBreakMode="CharacterWrap" />
                            <Label x:Name="ExtractionStatusLabel" Text="Extraction status: -" Style="{StaticResource MetaText}" />
                            <Label x:Name="OcrRequiredLabel" Text="OCR required: -" Style="{StaticResource MetaText}" />
                            <Label x:Name="DocumentTypeLabel" Text="Document type: -" Style="{StaticResource MetaText}" />
                            <Label x:Name="RedactionStatusLabel" Text="Redaction status: -" Style="{StaticResource MetaText}" />
                        </VerticalStackLayout>
                        <Label Text="Extracted Text" Style="{StaticResource SectionTitle}" />
                        <CollectionView x:Name="ExtractedTextCollection"
                                        EmptyView="No embedded text is available for this document. OCR is not implemented yet.">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Padding="0,0,0,14" Spacing="4">
                                        <Label Text="{Binding PageLabel}" Style="{StaticResource CardTitle}" />
                                        <Label Text="{Binding Text}" LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <Border Style="{StaticResource StatusBadge}" HorizontalOptions="Start">
                            <Label x:Name="ExtractionMethodLabel" Text="Extraction: none" Style="{StaticResource MetaText}" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Evidence Candidates" Style="{StaticResource SectionTitle}" />
                        <Label Text="Phase 2 TODO: create user-reviewed evidence candidates from extracted text while preserving source page references."
                               Style="{StaticResource MetaText}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource WarningCallout}">
                    <Label Text="No medical or legal conclusions are generated here. This page only helps review source material and user-selected evidence."
                           LineBreakMode="WordWrap" />
                </Border>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
